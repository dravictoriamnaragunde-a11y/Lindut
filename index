                    let exactos = this.profesionales.filter(p => p.cat === idCat && p.zona.toLowerCase().includes(zonaCliente));
                    let mismos = this.profesionales.filter(p => p.cat === idCat && !p.zona.toLowerCase().includes(zonaCliente));
                    let resultado = exactos.length > 0 ? exactos : (mismos.length > 0 ? mismos : this.profesionales);
                    return resultado.sort((a, b) => {
                        const aZona = a.zona.toLowerCase().includes(zonaCliente) ? 0 : 1;
                        const bZona = b.zona.toLowerCase().includes(zonaCliente) ? 0 : 1;
                        if (aZona !== bZona) return aZona - bZona;
                        return b.match - a.match;
