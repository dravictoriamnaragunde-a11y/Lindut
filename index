<!DOCTYPE html>
<html lang="es-AR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lindüt — Belleza a tu medida</title>
    <meta name="description" content="Lindüt conecta clientes con profesionales de estética independientes verificados. Manicuras, peluqueras, barberos, maquilladoras y más. Vos elegís quién y a qué precio.">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500&family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,500&family=Great+Vibes&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'lindut-black': '#1A0F1C',
                        'lindut-dark': '#2D1B2E',
                        'lindut-wine': '#4A1C3D',
                        'lindut-rose': '#8B3A5C',
                        'lindut-blush': '#C06C84',
                        'lindut-pink': '#D4A5A5',
                        'lindut-cream': '#F5E6D3',
                        'lindut-gold': '#C9A96E',
                        'lindut-gold-light': '#E8D5B7',
                        'lindut-gold-dark': '#A67B5B',
                        'lindut-champagne': '#F0E6D2',
                        'lindut-lavender': '#9B8AA5',
                        'lindut-sage': '#8FA68E',
                        'lindut-ivory': '#FAF7F2',
                        'lindut-stone': '#E8E0E3',
                        'lindut-espresso': '#3D2B3E',
                        'lindut-taupe': '#B8A9A1',
                        'lindut-warm-white': '#FDF9F6',
                    },
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        serif: ['Cormorant Garamond', 'serif'],
                        display: ['Playfair Display', 'serif'],
                        script: ['Great Vibes', 'cursive'],
                    }
                }
            }
        }
    </script>
    <style>
        [x-cloak] { display: none !important; }
        body:not(.alpine-ready) [x-data] { display: none !important; }
        .text-gold-gradient { background: linear-gradient(135deg, #C9A96E 0%, #E8D5B7 50%, #A67B5B 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
        .text-rose-gradient { background: linear-gradient(135deg, #C06C84 0%, #8B3A5C 50%, #4A1C3D 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
        .glass-panel { background: rgba(255, 255, 255, 0.97); backdrop-filter: blur(20px); border: 1px solid rgba(201, 169, 110, 0.15); }
        .glass-dark { background: rgba(45, 27, 46, 0.95); backdrop-filter: blur(20px); border: 1px solid rgba(201, 169, 110, 0.1); }
        .card-hover { transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); border: 1px solid transparent; }
        .card-hover:hover { border-color: #C9A96E; transform: translateY(-4px); box-shadow: 0 20px 40px rgba(74, 28, 61, 0.12); }
        .btn-gold { background: linear-gradient(135deg, #C9A96E 0%, #A67B5B 100%); transition: all 0.3s ease; }
        .btn-gold:hover { transform: translateY(-2px); box-shadow: 0 10px 30px rgba(201, 169, 110, 0.35); }
        .btn-wine { background: linear-gradient(135deg, #4A1C3D 0%, #2D1B2E 100%); transition: all 0.3s ease; }
        .btn-wine:hover { transform: translateY(-2px); box-shadow: 0 10px 30px rgba(74, 28, 61, 0.35); }
        .btn-blush { background: linear-gradient(135deg, #C06C84 0%, #8B3A5C 100%); transition: all 0.3s ease; }
        .btn-blush:hover { transform: translateY(-2px); box-shadow: 0 10px 30px rgba(192, 108, 132, 0.35); }
        .input-lindut { transition: all 0.3s ease; border: 1.5px solid #E8E0E3; background: #FDF9F6; }
        .input-lindut:focus { border-color: #C9A96E; box-shadow: 0 0 0 3px rgba(201, 169, 110, 0.15); outline: none; background: white; }
        .fade-in { animation: fadeIn 0.6s ease-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
        .shimmer { background: linear-gradient(90deg, transparent, rgba(201,169,110,0.08), transparent); background-size: 200% 100%; animation: shimmer 2s infinite; }
        @keyframes shimmer { 0% { background-position: -200% 0; } 100% { background-position: 200% 0; } }
        .logo-lindut { filter: drop-shadow(0 4px 12px rgba(201, 169, 110, 0.2)); }
        .admin-trigger { position: fixed; bottom: 8px; right: 8px; width: 14px; height: 14px; background: linear-gradient(135deg, #C9A96E, #A67B5B); border-radius: 50%; opacity: 0.12; cursor: pointer; z-index: 9999; transition: all 0.3s ease; }
        .admin-trigger:hover { opacity: 0.8; transform: scale(1.3); box-shadow: 0 4px 15px rgba(201,169,110,0.4); }
        .pro-trigger { position: fixed; bottom: 8px; left: 8px; width: 14px; height: 14px; background: linear-gradient(135deg, #4A1C3D, #8B3A5C); border-radius: 50%; opacity: 0.12; cursor: pointer; z-index: 9999; transition: all 0.3s ease; }
        .pro-trigger:hover { opacity: 0.8; transform: scale(1.3); box-shadow: 0 4px 15px rgba(74,28,61,0.4); }
        .scroll-hide::-webkit-scrollbar { display: none; }
        .scroll-hide { -ms-overflow-style: none; scrollbar-width: none; }
        .star-rating { color: #C9A96E; }
        .tag-pill { background: linear-gradient(135deg, rgba(201,169,110,0.1), rgba(201,169,110,0.05)); border: 1px solid rgba(201,169,110,0.2); }
        .separator-gold { height: 1px; background: linear-gradient(90deg, transparent, #C9A96E, transparent); }
        .hero-pattern { background-image: radial-gradient(circle at 25% 25%, rgba(201,169,110,0.03) 0%, transparent 50%), radial-gradient(circle at 75% 75%, rgba(192,108,132,0.03) 0%, transparent 50%); }
        .font-display { font-family: 'Cormorant Garamond', serif; }
        .font-body { font-family: 'Inter', sans-serif; }
        .tracking-luxury { letter-spacing: 0.25em; }
        .tracking-elegant { letter-spacing: 0.15em; }
        .micro-accent::after { content: ''; display: block; width: 24px; height: 1px; background: linear-gradient(90deg, #C9A96E, #E8D5B7); margin-top: 8px; }
        .texture-overlay { position: relative; }
        .texture-overlay::before { content: ''; position: absolute; inset: 0; background-image: url("data:image/svg+xml,%3Csvg width='100' height='100' viewBox='0 0 100 100' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E"); pointer-events: none; z-index: 1; }
        .elegant-scroll::-webkit-scrollbar { width: 4px; }
        .elegant-scroll::-webkit-scrollbar-track { background: transparent; }
        .elegant-scroll::-webkit-scrollbar-thumb { background: linear-gradient(180deg, #C9A96E, #E8D5B7); border-radius: 4px; }
        .shadow-luxury { box-shadow: 0 4px 20px rgba(26, 15, 28, 0.06), 0 1px 3px rgba(26, 15, 28, 0.04); }
        .heritage-serif { font-family: 'Cormorant Garamond', serif; font-weight: 300; letter-spacing: 0.02em; }
    </style>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
<base target="_blank">
<base target="_blank">
</head>
<body class="font-body bg-lindut-warm-white text-lindut-dark antialiased" x-data="lindutApp()">
    <script>
        document.addEventListener('alpine:init', function() {
            document.body.classList.add('alpine-ready');
        });
    </script>

    <!-- ADMIN TRIGGER -->
    <div class="admin-trigger" @click="abrirAdmin()" title="Panel Admin"></div>
    <!-- PROFESIONAL TRIGGER -->
    <div class="pro-trigger" @click="abrirPanelProfesional()" title="Panel Profesional"></div>

    <!-- MODAL LOGIN ADMIN -->
    <div x-show="adminModal" x-cloak class="fixed inset-0 z-[100] flex items-center justify-center bg-black/60 backdrop-blur-md" @click.self="adminModal = false">
        <div class="bg-white rounded-2xl shadow-2xl p-8 max-w-sm w-full mx-4 border border-lindut-stone">
            <div class="text-center mb-6">
                <div class="w-14 h-14 bg-lindut-black rounded-2xl flex items-center justify-center mx-auto mb-3 shadow-lg">
                    <span class="text-2xl">🔐</span>
                </div>
                <h3 class="text-lg font-display font-bold text-lindut-black">Panel de Validación</h3>
                <p class="text-xs text-lindut-lavender mt-1 tracking-elegant">Acceso exclusivo administrador</p>
            </div>
            <form @submit.prevent="loginAdmin()" class="space-y-4">
                <div>
                    <input type="password" x-model="adminPassword" placeholder="Contraseña de admin" class="input-lindut w-full px-4 py-3 rounded-xl text-sm text-center font-mono tracking-widest">
                </div>
                <p x-show="adminError" x-text="adminError" class="text-xs text-red-500 text-center font-medium"></p>
                <button type="submit" class="w-full btn-wine text-white py-3 rounded-xl font-bold text-sm tracking-wide">Ingresar</button>
            </form>
        </div>
    </div>

    <!-- HEADER -->
    <header class="fixed top-0 left-0 right-0 z-50 glass-panel shadow-sm border-b border-lindut-stone/50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-18">
                <div class="flex items-center gap-3 cursor-pointer" @click="view = 'home'">
                    <!-- NEW LINDÜT LOGO - Quiet Luxury Heritage Design -->
                    <svg class="w-10 h-10 logo-lindut" viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <defs>
                            <linearGradient id="goldRing" x1="0%" y1="0%" x2="100%" y2="100%">
                                <stop offset="0%" stop-color="#E8D5B7"/>
                                <stop offset="40%" stop-color="#C9A96E"/>
                                <stop offset="70%" stop-color="#A67B5B"/>
                                <stop offset="100%" stop-color="#8B6914"/>
                            </linearGradient>
                            <linearGradient id="wineGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                                <stop offset="0%" stop-color="#5A2448"/>
                                <stop offset="50%" stop-color="#4A1C3D"/>
                                <stop offset="100%" stop-color="#2D1B2E"/>
                            </linearGradient>
                            <linearGradient id="blushGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                                <stop offset="0%" stop-color="#D4A5A5"/>
                                <stop offset="50%" stop-color="#C06C84"/>
                                <stop offset="100%" stop-color="#8B3A5C"/>
                            </linearGradient>
                            <filter id="dropShadowGold" x="-30%" y="-30%" width="160%" height="160%">
                                <feDropShadow dx="1" dy="3" stdDeviation="5" flood-color="#C9A96E" flood-opacity="0.2"/>
                            </filter>
                        </defs>
                        <ellipse cx="60" cy="112" rx="36" ry="8" fill="#1A0F1C" opacity="0.06"/>
                        <circle cx="60" cy="60" r="54" fill="none" stroke="url(#goldRing)" stroke-width="1.5" opacity="0.85"/>
                        <circle cx="60" cy="60" r="50" fill="none" stroke="#C9A96E" stroke-width="0.4" opacity="0.25"/>
                        <circle cx="60" cy="6" r="1.5" fill="#C9A96E" opacity="0.6"/>
                        <circle cx="60" cy="114" r="1.5" fill="#C9A96E" opacity="0.6"/>
                        <circle cx="6" cy="60" r="1.5" fill="#C9A96E" opacity="0.6"/>
                        <circle cx="114" cy="60" r="1.5" fill="#C9A96E" opacity="0.6"/>
                        <path d="M60 16 C 38 16, 22 34, 22 56 C 22 78, 38 94, 60 98 C 82 94, 98 78, 98 56 C 98 34, 82 16, 60 16 Z" fill="url(#wineGrad)" stroke="url(#goldRing)" stroke-width="1.2" filter="url(#dropShadowGold)"/>
                        <path d="M60 26 C 46 26, 36 38, 36 54 C 36 70, 46 82, 60 86 C 74 82, 84 70, 84 54 C 84 38, 74 26, 60 26 Z" fill="url(#blushGrad)" opacity="0.5"/>
                        <path d="M60 32 Q 54 44 48 56 Q 54 50 60 48 Q 66 50 72 56 Q 66 44 60 32" fill="#E8D5B7" opacity="0.85"/>
                        <circle cx="60" cy="60" r="10" fill="none" stroke="url(#goldRing)" stroke-width="1" opacity="0.5"/>
                        <circle cx="60" cy="60" r="7" fill="none" stroke="#E8D5B7" stroke-width="0.5" opacity="0.3"/>
                        <path d="M44 74 Q 60 88 76 74" fill="none" stroke="#C9A96E" stroke-width="1.2" stroke-linecap="round" opacity="0.6"/>
                        <path d="M34 40 Q 40 36 46 42" fill="none" stroke="#E8D5B7" stroke-width="0.8" stroke-linecap="round" opacity="0.35"/>
                        <path d="M86 40 Q 80 36 74 42" fill="none" stroke="#E8D5B7" stroke-width="0.8" stroke-linecap="round" opacity="0.35"/>
                        <text x="60" y="108" text-anchor="middle" fill="#C9A96E" font-size="4" font-family="'Cormorant Garamond', serif" letter-spacing="2" opacity="0.5">EST. 2026</text>
                    </svg>
                    <div>
                        <span class="text-2xl font-display font-light text-gold-gradient tracking-tight">Lindüt</span>
                        <span class="hidden sm:inline text-[10px] text-lindut-lavender ml-2 tracking-[0.3em] uppercase font-body">Argentina</span>
                    </div>
                </div>
                <nav class="hidden md:flex items-center gap-6">
                    <button @click="view = 'home'" class="text-sm font-medium text-lindut-lavender hover:text-lindut-wine transition-colors cursor-pointer tracking-elegant">Inicio</button>
                    <button @click="view = 'cliente'" class="text-sm font-medium text-lindut-lavender hover:text-lindut-wine transition-colors cursor-pointer tracking-elegant">Soy Cliente</button>
                    <button @click="view = 'profesional'" class="text-sm font-medium text-lindut-lavender hover:text-lindut-wine transition-colors cursor-pointer tracking-elegant">Soy Profesional</button>
                    <button @click="view = 'login-profesional'" class="text-sm font-medium text-lindut-gold hover:text-lindut-gold-dark transition-colors cursor-pointer font-bold tracking-elegant">✨ Acceso Profesionales</button>
                    <button @click="view = 'tyc'" class="text-sm font-medium text-lindut-lavender hover:text-lindut-wine transition-colors cursor-pointer tracking-elegant">Términos</button>
                </nav>
                <button @click="mobileMenu = !mobileMenu" class="md:hidden p-2 rounded-lg hover:bg-lindut-cream/50">
                    <svg class="w-6 h-6 text-lindut-wine" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
                </button>
            </div>
        </div>
        <div x-show="mobileMenu" x-cloak x-transition class="md:hidden border-t border-lindut-stone bg-white">
            <div class="px-4 py-3 space-y-2">
                <button @click="view = 'home'; mobileMenu = false" class="block w-full text-left px-3 py-2 rounded-lg hover:bg-lindut-cream/30 text-sm font-medium cursor-pointer tracking-elegant">Inicio</button>
                <button @click="view = 'cliente'; mobileMenu = false" class="block w-full text-left px-3 py-2 rounded-lg hover:bg-lindut-cream/30 text-sm font-medium cursor-pointer tracking-elegant">Soy Cliente</button>
                <button @click="view = 'profesional'; mobileMenu = false" class="block w-full text-left px-3 py-2 rounded-lg hover:bg-lindut-cream/30 text-sm font-medium cursor-pointer tracking-elegant">Soy Profesional</button>
                <button @click="view = 'login-profesional'; mobileMenu = false" class="block w-full text-left px-3 py-2 rounded-lg hover:bg-lindut-cream/30 text-sm font-medium cursor-pointer text-lindut-gold font-bold tracking-elegant">✨ Acceso Profesionales</button>
                <button @click="view = 'tyc'; mobileMenu = false" class="block w-full text-left px-3 py-2 rounded-lg hover:bg-lindut-cream/30 text-sm font-medium cursor-pointer tracking-elegant">Términos y Condiciones</button>
            </div>
        </div>
    </header>

    <div class="h-18"></div>

    <!-- VIEW: ADMIN -->
    <div x-show="view === 'admin'" x-cloak class="min-h-screen bg-lindut-warm-white pb-20 fade-in">
        <div class="bg-lindut-black border-b border-lindut-wine/30">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
                <div class="flex items-center justify-between">
                    <div>
                        <button @click="view = 'home'" class="text-sm text-lindut-lavender hover:text-lindut-cream flex items-center gap-1 tracking-elegant">← Volver al inicio</button>
                        <h1 class="text-2xl sm:text-3xl font-display font-bold text-lindut-cream mt-2">🔐 Panel de Validación de Pagos</h1>
                    </div>
                    <div class="flex items-center gap-3">
                        <button @click="view = 'admin-profesionales'" class="text-xs btn-blush text-white px-4 py-2 rounded-lg font-bold transition tracking-elegant">👥 Gestión Profesionales</button>
                        <div class="text-xs text-lindut-lavender bg-lindut-dark px-3 py-1.5 rounded-lg tracking-elegant">Admin: Activo</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="max-w-4xl mx-auto px-4 py-8 space-y-8">
            <div class="bg-white rounded-2xl shadow-luxury p-8 border border-lindut-stone">
                <h2 class="text-xl font-display font-bold text-lindut-black mb-2">Generar Código de Desbloqueo</h2>
                <p class="text-sm text-lindut-lavender mb-6 tracking-elegant">Ingresá el monto exacto acreditado en la cuenta bancaria para generar el código único de validación.</p>
                <div class="grid md:grid-cols-2 gap-4 mb-6">
                    <div>
                        <label class="block text-xs font-bold text-lindut-wine mb-1 tracking-elegant">Monto acreditado ($ARS) *</label>
                        <input type="number" x-model="adminMonto" placeholder="Ej: 15000" class="input-lindut w-full px-4 py-3 rounded-xl text-sm font-mono">
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-lindut-wine mb-1 tracking-elegant">ID de Solicitud (opcional)</label>
                        <input type="text" x-model="adminSolicitudId" placeholder="Ej: LND-001" class="input-lindut w-full px-4 py-3 rounded-xl text-sm font-mono">
                    </div>
                </div>
                <button @click="generarCodigoAdmin()" class="btn-gold text-white px-6 py-3 rounded-xl font-bold text-sm tracking-elegant">Generar Código de Validación</button>
                <div x-show="codigoGenerado" class="mt-6 bg-emerald-50/80 border border-emerald-200 rounded-xl p-6 text-center">
                    <p class="text-xs text-emerald-700 font-bold uppercase tracking-wider mb-2 tracking-luxury">Código Generado — Desbloqueo Habilitado</p>
                    <div class="flex items-center justify-center gap-3">
                        <div class="bg-white border-2 border-emerald-300 rounded-xl px-6 py-4">
                            <span class="text-3xl font-black font-mono tracking-[0.3em] text-emerald-800" x-text="codigoGenerado"></span>
                        </div>
                        <button @click="copiarCodigoAdmin()" class="bg-emerald-600 text-white px-4 py-3 rounded-xl text-sm font-bold hover:bg-emerald-700 transition tracking-elegant">📋 Copiar</button>
                    </div>
                    <p class="text-[10px] text-emerald-500 mt-3 tracking-elegant">Este código expira a las 23:59 hs del día de hoy. El profesional puede verificar el desbloqueo desde su pantalla ingresando el monto exacto.</p>
                </div>
            </div>
            <div class="bg-white rounded-2xl shadow-luxury p-8 border border-lindut-stone">
                <h2 class="text-lg font-display font-bold text-lindut-black mb-4">Códigos Generados Hoy</h2>
                <div x-show="codigosHistorial.length === 0" class="text-sm text-lindut-lavender text-center py-8 tracking-elegant">No se generaron códigos hoy.</div>
                <div class="space-y-2">
                    <template x-for="(item, idx) in codigosHistorial" :key="idx">
                        <div class="flex items-center justify-between bg-lindut-warm-white rounded-lg p-3 border border-lindut-stone">
                            <div>
                                <span class="font-mono font-bold text-lindut-black text-sm" x-text="item.codigo"></span>
                                <span class="text-xs text-lindut-lavender ml-2" x-text="'$' + item.monto + ' ARS'"></span>
                                <span class="text-[10px] text-lindut-lavender/60 ml-2" x-text="item.hora"></span>
                            </div>
                            <span class="text-[10px] px-2 py-1 rounded-full font-bold tracking-elegant" :class="item.usado ? 'bg-emerald-100 text-emerald-700' : 'bg-amber-100 text-amber-700'" x-text="item.usado ? 'Usado' : 'Activo'"></span>
                        </div>
                    </template>
                </div>
            </div>
        </div>
    </div>

    <!-- VIEW: ADMIN PROFESIONALES -->
    <div x-show="view === 'admin-profesionales'" x-cloak class="min-h-screen bg-lindut-warm-white pb-20 fade-in">
        <div class="bg-lindut-black border-b border-lindut-wine/30">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
                <div class="flex items-center justify-between">
                    <div>
                        <button @click="view = 'admin'" class="text-sm text-lindut-lavender hover:text-lindut-cream flex items-center gap-1 tracking-elegant">← Volver a Validación</button>
                        <h1 class="text-2xl sm:text-3xl font-display font-bold text-lindut-cream mt-2">👥 Gestión de Profesionales</h1>
                    </div>
                    <div class="flex items-center gap-3">
                        <button @click="exportarCSV()" class="text-xs bg-emerald-700 hover:bg-emerald-600 text-white px-3 py-2 rounded-lg font-bold transition tracking-elegant">📊 Exportar CSV</button>
                        <div class="text-xs text-lindut-lavender bg-lindut-dark px-3 py-1.5 rounded-lg tracking-elegant">Admin: Activo</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="max-w-6xl mx-auto px-4 py-8 space-y-8">
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                <div class="bg-white rounded-xl shadow-luxury p-4 border border-lindut-stone text-center">
                    <p class="text-2xl font-black text-lindut-wine font-display" x-text="profesionalesRegistrados.length"></p>
                    <p class="text-xs text-lindut-lavender font-bold tracking-elegant">Total Profesionales</p>
                </div>
                <div class="bg-white rounded-xl shadow-luxury p-4 border border-lindut-stone text-center">
                    <p class="text-2xl font-black text-emerald-600 font-display" x-text="profesionalesActivos().length"></p>
                    <p class="text-xs text-lindut-lavender font-bold tracking-elegant">Activos</p>
                </div>
