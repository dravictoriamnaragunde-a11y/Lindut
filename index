                    let hash = 0;
                    for (let i = 0; i < str.length; i++) { const char = str.charCodeAt(i); hash = ((hash << 5) - hash) + char; hash = hash & hash; }
                    let codigo = Math.abs(hash).toString(36).toUpperCase().padEnd(6, '0').substring(0, 6);
                    if (codigo.length < 6) codigo = codigo + '0'.repeat(6 - codigo.length);
                    this.codigoGenerado = codigo;
