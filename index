                        pro.telefono = this.editForm.telefono.trim(); pro.especialidad = this.editForm.especialidad; pro.cuit = this.editForm.cuit.trim();
                        pro.experiencia = this.editForm.experiencia; pro.modalidad = this.editForm.modalidad;
                        this.profesionalEditando = null;
                    }
                },

                verHistorialOPs(pro) { this.profesionalHistorial = pro; this.modalHistorialOPs = true; },
                verDetalleProfesional(pro) { this.profesionalDetalle = pro; this.modalDetalleProfesional = true; },

                toggleEstadoProfesionalAdmin(usuario) {
                    const pro = this.profesionalesRegistrados.find(p => p.usuario === usuario);
                    if (!pro) return;
                    if (pro.activo !== false) { if (confirm('¿Dar de baja a ' + pro.nombre + ' ' + pro.apellido + '?')) { pro.activo = false; pro.fechaBaja = new Date().toLocaleString('es-AR'); } }
                    else { pro.activo = true; delete pro.fechaBaja; }
                },

                reactivarProfesional(usuario) { const pro = this.profesionalesRegistrados.find(p => p.usuario === usuario); if (pro) { pro.activo = true; delete pro.fechaBaja; } },

                eliminarProfesionalAdmin(usuario) {
                    const pro = this.profesionalesRegistrados.find(p => p.usuario === usuario);
                    if (!pro) return;
                    if (confirm('¿ELIMINAR DEFINITIVAMENTE a ' + pro.nombre + ' ' + pro.apellido + '?')) { const idx = this.profesionalesRegistrados.findIndex(p => p.usuario === usuario); if (idx !== -1) this.profesionalesRegistrados.splice(idx, 1); }
                },

                abrirAsignarOP(pro) {
                    if (pro.activo === false) { alert('No se puede asignar una OP a un profesional dado de baja. Reactivalo primero.'); return; }
                    this.profesionalAsignarOP = pro;
                    this.opManualForm = { numero: 'LND-' + Date.now(), categoria: 'Manicura 💅', zona: '', diagnostico: '', monto: '', estado: 'pendiente', clienteNombre: '', clienteTelefono: '', clienteEmail: '' };
                    this.modalAsignarOP = true;
                },

                async guardarOPManual() {
                    if (!this.opManualForm.numero || !this.opManualForm.categoria || !this.opManualForm.zona || !this.opManualForm.diagnostico) { alert('Completá todos los campos obligatorios.'); return; }
                    const nuevaOP = { numero: this.opManualForm.numero, categoria: this.opManualForm.categoria, zona: this.opManualForm.zona, diagnostico: this.opManualForm.diagnostico, monto: this.opManualForm.monto || 0, canon: this.opManualForm.monto ? Math.round(this.opManualForm.monto * 0.01) : 0, estado: this.opManualForm.estado, clienteNombre: this.opManualForm.clienteNombre, clienteTelefono: this.opManualForm.clienteTelefono, clienteEmail: this.opManualForm.clienteEmail, fechaAsignacion: new Date().toLocaleString('es-AR'), asignadaPor: 'Admin' };
                    if (!this.profesionalAsignarOP.opsAsignadas) this.profesionalAsignarOP.opsAsignadas = [];
                    this.profesionalAsignarOP.opsAsignadas.push(nuevaOP);
                    await this.enviarAlertaOPPorEmail(nuevaOP, this.profesionalAsignarOP.email);
                    alert('✅ OP asignada con éxito a ' + this.profesionalAsignarOP.nombre + ' ' + this.profesionalAsignarOP.apellido + '\n\nSe envió una alerta por email a ' + this.profesionalAsignarOP.email);
                    this.modalAsignarOP = false; this.profesionalAsignarOP = null;
                },

                exportarCSV() {
                    const headers = ['Nombre', 'Apellido', 'Usuario', 'DNI', 'Email', 'Telefono', 'Especialidad', 'Experiencia', 'Modalidad', 'Estado', 'Fecha Alta', 'OPs Asignadas'];
                    const rows = this.profesionalesRegistrados.map(p => [p.nombre, p.apellido, p.usuario, p.dni, p.email, p.telefono || '', p.especialidad, p.experiencia || '0', p.modalidad || '', p.activo !== false ? 'ACTIVO' : 'BAJA', p.fechaAlta || '', (p.opsAsignadas ? p.opsAsignadas.length : 0).toString()]);
                    const csvContent = [headers.join(','), ...rows.map(r => r.map(cell => '"' + String(cell).replace(/"/g, '""') + '"').join(','))].join('\n');
                    const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
                    const link = document.createElement('a'); link.href = URL.createObjectURL(blob); link.download = 'profesionales_lindut_' + new Date().toISOString().split('T')[0] + '.csv'; link.click();
                },

                profesionales: [
                    { id: 1, nombre: 'María López', especialidad: 'Manicura Profesional', zona: 'Palermo, CABA', experiencia: 8, match: 96, cat: 'manicura' },
                    { id: 2, nombre: 'Carla Fernández', especialidad: 'Peluquera / Colorista', zona: 'Belgrano, CABA', experiencia: 12, match: 94, cat: 'peluqueria' },
                    { id: 3, nombre: 'Lucas Martínez', especialidad: 'Barbero Clásico', zona: 'Palermo, CABA', experiencia: 6, match: 92, cat: 'barberia' },
                    { id: 4, nombre: 'Sofía Ruiz', especialidad: 'Maquilladora Profesional', zona: 'Recoleta, CABA', experiencia: 10, match: 95, cat: 'maquillaje' },
                    { id: 5, nombre: 'Valentina Sosa', especialidad: 'Esteticista Facial', zona: 'Palermo, CABA', experiencia: 7, match: 91, cat: 'estetica' },
                    { id: 6, nombre: 'Julieta Morales', especialidad: 'Depiladora Certificada', zona: 'Caballito, CABA', experiencia: 9, match: 89, cat: 'depilacion' },
                    { id: 7, nombre: 'Camila Torres', especialidad: 'Masajista / Spa', zona: 'Palermo, CABA', experiencia: 11, match: 93, cat: 'masajes' },
                    { id: 8, nombre: 'Florencia Díaz', especialidad: 'Lash & Brow Artist', zona: 'Belgrano, CABA', experiencia: 5, match: 90, cat: 'pestana' }
                ]
            }
        }
    </script>
