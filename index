                    this.codigoError = '';
                    if (!this.canonCodigoValidar || !this.canonMontoValidar) { this.codigoError = 'Completá el código y el monto transferido.'; return; }
                    const fecha = new Date().toISOString().split('T')[0];
                    const salt = 'LINDUT_ARG_SECRET_2026_V1';
                    const str = this.canonMontoValidar.toString() + fecha + salt;
                    let hash = 0;
                    for (let i = 0; i < str.length; i++) { const char = str.charCodeAt(i); hash = ((hash << 5) - hash) + char; hash = hash & hash; }
                    let codigoEsperado = Math.abs(hash).toString(36).toUpperCase().padEnd(6, '0').substring(0, 6);
                    if (codigoEsperado.length < 6) codigoEsperado = codigoEsperado + '0'.repeat(6 - codigoEsperado.length);
                    if (this.canonCodigoValidar.toUpperCase() === codigoEsperado) {
                        this.canonLiquidado = true; this.pagoPendienteValidacion = false; this.mostrarValidacionCodigo = false; this.codigoError = '';
